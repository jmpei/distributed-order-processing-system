# Copy this file to terraform.tfvars and fill in admin_cidr.
# terraform.tfvars is gitignored — never commit real values.

# Your laptop's public IP, /32. Required for `deploy.sh` to reach RDS on
# 3306 to create per-service schemas. Find it with:
#   curl -s https://checkip.amazonaws.com
# Then suffix /32, e.g. "203.0.113.42/32".
admin_cidr = "REPLACE_WITH_YOUR_IP/32"

# Optional overrides (defaults in variables.tf are fine for dev):
# region              = "us-west-2"
# project             = "dop"
# environment         = "dev"
# image_tag           = "latest"
# fargate_cpu         = 256
# fargate_memory      = 512
# db_instance_class   = "db.t4g.micro"
# mq_instance_type    = "mq.t3.micro"

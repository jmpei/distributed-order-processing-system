# Copy to .env and adjust as needed. docker-compose reads .env automatically
# from the directory it is run in (deploy/), so place a copy there too.

# ── MySQL ──────────────────────────────────────────────────────
# Shared root password across all three MySQL instances. Used by the
# services to authenticate and by the compose healthcheck.
MYSQL_ROOT_PASSWORD=rootpw

# ── inventory-service tunables ─────────────────────────────────
# Optimistic-lock retry budget per reserve command. Bump if a hot SKU
# experiences sustained contention beyond this cap.
INVENTORY_RESERVE_MAX_RETRIES=50

# ── payment-service tunables (testing only) ────────────────────
# 0.0 = always succeed, 1.0 = always fail. Drives the saga compensation
# path under controlled failure injection. Leave 0.0 in production.
PAYMENT_FAILURE_RATE=0.0


# ── For running services OUTSIDE docker-compose ────────────────
# When a service runs locally (go run ./cmd), it reads each of the
# following directly. Inside docker-compose these are hardcoded in
# deploy/docker-compose.yml; the values below match the defaults baked
# into each service's internal/config/config.go.

# Common (every service)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=rootpw
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Per-service HTTP port + DB schema
# ORDER_PORT=8081
# DB_NAME=orders_db          # for order-service

# INVENTORY_PORT=8082
# DB_NAME=inventory_db       # for inventory-service

# PAYMENT_PORT=8083
# DB_NAME=payments_db        # for payment-service
